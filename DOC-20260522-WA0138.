<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Santizn$ Precios</title>
    <style>
        body {
            background: #0d0d0d;
            color: #fff;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
        }
        h1 {
            color: #00ff88;
            text-align: center;
            margin-bottom: 10px;
            font-size: 28px;
        }
        h2 {
            color: #fff;
            margin: 0 0 10px 0;
            font-size: 18px;
        }
        .subtitle {
            color: #aaa;
            text-align: center;
            margin-bottom: 20px;
            font-size: 14px;
        }
        .card {
            background: #1a1a1a;
            border-radius: 12px;
            padding: 15px;
            margin: 15px 0;
        }
        .tag {
            background: #00ff88;
            color: #000;
            padding: 3px 8px;
            border-radius: 6px;
            font-size: 12px;
            margin-left: 8px;
        }
        .row {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            font-size: 15px;
        }
        .price {
            color: #00ff88;
            font-weight: bold;
        }
    </style>
</head>
